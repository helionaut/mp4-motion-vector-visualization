{
  "run_id": "public-known-good-baseline",
  "description": "Deterministic shareable MP4 fixture pair generated with FFmpeg lavfi sources inside the documented Docker environment.",
  "environment_contract": {
    "wrapper": "scripts/run_in_docker.sh",
    "strategy": "docker"
  },
  "inputs": [
    {
      "name": "synthetic-grid",
      "source_kind": "generated-public-fixture",
      "relative_output_path": "datasets/fixtures/public-known-good/synthetic-grid.mp4",
      "generator": {
        "video_filter": "testsrc2=duration=3:size=320x180:rate=12",
        "frame_rate": 12,
        "codec": "libx264",
        "pixel_format": "yuv420p",
        "gop_size": 12,
        "bf": 2
      }
    },
    {
      "name": "synthetic-rotating-pattern",
      "source_kind": "generated-public-fixture",
      "relative_output_path": "datasets/fixtures/public-known-good/synthetic-rotating-pattern.mp4",
      "generator": {
        "video_filter": "testsrc=duration=3:size=320x180:rate=12,rotate=0.05*t:c=black@0",
        "frame_rate": 12,
        "codec": "libx264",
        "pixel_format": "yuv420p",
        "gop_size": 12,
        "bf": 2
      }
    }
  ],
  "artifacts": {
    "report_dir": "reports/out/public-known-good-baseline",
    "vectors_dir": "reports/out/public-known-good-baseline/vectors",
    "renders_dir": "reports/out/public-known-good-baseline/renders",
    "comparison_dir": "reports/out/public-known-good-baseline/comparison"
  }
}
